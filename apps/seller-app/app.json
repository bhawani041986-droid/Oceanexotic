{
    "expo":  {
                 "name":  "OceanExotic Seller",
                 "slug":  "oceanexotic-seller",
                 "version":  "1.0.0",
                 "orientation":  "portrait",
                 "scheme":  "oceanexotic",
                 "userInterfaceStyle":  "dark",
                 "newArchEnabled":  true,
                 "assetBundlePatterns":  [
                                             "assets/**"
                                         ],
                 "android":  {
                                 "package":  "com.oceanexotic.seller",
                                 "usesCleartextTraffic":  true
                             },
                 "ios":  {
                             "infoPlist":  {
                                               "NSAppTransportSecurity":  {
                                                                              "NSAllowsArbitraryLoads":  true,
                                                                              "NSAllowsLocalNetworking":  true
                                                                          }
                                           }
                         },
                 "web":  {
                             "bundler":  "metro",
                             "output":  "static"
                         },
                 "plugins":  [
                                 "expo-router"
                             ],
                 "experiments":  {
                                     "typedRoutes":  true
                                 },
                 "extra":  {
                               "router":  {

                                          },
                               "eas":  {

                                       }
                           },
                 "owner":  "bhawani-ocean"
             }
}
