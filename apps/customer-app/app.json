{
  "expo": {
    "name": "OceanExotic Customer",
    "slug": "oceanexotic-customer",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "oceanexotic",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#050B18"
    },
    "assetBundlePatterns": [
      "assets/**"
    ],
    "android": {
      "package": "com.oceanexotic.customer",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#050B18"
      }
    },
    "ios": {
      "infoPlist": {
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true,
          "NSAllowsLocalNetworking": true
        }
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "./withSplitApks.js",
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "d4eb0b50-19be-4469-bbe6-1f1209eb743d"
      }
    },
    "owner": "oceanxy"
  }
}
