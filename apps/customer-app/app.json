{
  "expo": {
    "name": "OceanExotic Customer",
    "slug": "oceanexotic-customer",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "oceanexotic",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "assetBundlePatterns": [
      "assets/**"
    ],
    "android": {
      "package": "com.oceanexotic.customer",
      "usesCleartextTraffic": true
    },
    "ios": {
      "infoPlist": {
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true,
          "NSAllowsLocalNetworking": true
        }
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "be276ec3-c30d-4cdd-82cd-bcce3039181e"
      }
    },
    "owner": "bhawani-ocean"
  }
}
