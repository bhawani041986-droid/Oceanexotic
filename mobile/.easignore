# Exclude node_modules - EAS installs these fresh
node_modules/

# Exclude native android folder - EAS runs prebuild on their server
android/

# Exclude native ios folder
ios/

# Exclude local env files
.env
.env.local
.env.*.local

# Exclude build outputs
dist/
.expo/

# Exclude logs
*.log
npm-debug.log*

# Exclude large zip files
*.zip
*.tgz

# Exclude gradle caches
.gradle/
