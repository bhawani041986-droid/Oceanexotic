{
  "expo": {
    "name": "OceanExotic",
    "slug": "oceanexotic-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "oceanexotic",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "assetBundlePatterns": [
      "assets/**"
    ],
    "android": {
      "usesCleartextTraffic": true,
      "package": "com.bhawaniocean.oceanexoticmobile"
    },
    "ios": {
      "infoPlist": {
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true,
          "NSAllowsLocalNetworking": true
        }
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-video",
      "expo-localization"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "d3e5e431-5d87-4a25-a2fa-1d8c0e3f234f"
      }
    }
  }
}
